{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "AI Evaluation Playbook",
  "colors": {
    "primary": "#6366F1",
    "light": "#A855F7",
    "dark": "#4338CA"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Design fundamentals",
            "pages": [
              "guides/principles",
              "guides/metrics",
              "guides/data"
            ]
          },
          {
            "group": "Execution playbooks",
            "pages": [
              "playbooks/manual-review",
              "playbooks/automation",
              "playbooks/monitoring"
            ]
          }
        ]
      },
      {
        "tab": "Templates",
        "groups": [
          {
            "group": "Artifacts",
            "pages": [
              "templates/rubric-example",
              "templates/checklist"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Community",
          "href": "https://evals.wiki",
          "icon": "users"
        },
        {
          "anchor": "Newsletter",
          "href": "https://evaluationinsights.example.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "sticky": true,
    "links": [
      {
        "label": "Contribute",
        "href": "mailto:evals@docs.example.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Eval toolkit",
      "href": "https://github.com/"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/",
      "github": "https://github.com/",
      "linkedin": "https://linkedin.com/"
    }
  }
}
